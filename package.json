{
  "name": "cside-static",
  "version": "1.0.0",
  "description": "Helper scripts for deploying cside-static to Cloudflare Workers/Pages",
  "private": true,
  "scripts": {
    "login": "npx wrangler@latest login",
    "deploy": "npx wrangler@latest deploy --assets ./public --name cside-static",
    "deploy:assets": "npx wrangler@latest deploy --assets ./public --name cside-static",
    "deploy:pages": "npx wrangler@latest pages publish ./public --project-name cside-static",
    "tail": "npx wrangler@latest tail"
  },
  "engines": {
    "node": ">=16"
  }
}
